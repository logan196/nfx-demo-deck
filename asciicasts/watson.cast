[0.000, "o", "    Ensembl     \u001b]8;;https://ensembl.org/Homo_sapiens/Gene/Summary?g=ENSG00000012048\u0007\u001b[36mhttps://ensembl.org/Homo_sapiens/Gene/Summary?g=ENSG00000012048\u001b[0m\u001b]8;;\u0007\r\n    NCBI Gene   \u001b]8;;https://www.ncbi.nlm.nih.gov/gene/?term=BRCA1\u0007\u001b[36mhttps://www.ncbi.nlm.nih.gov/gene/?term=BRCA1\u001b[0m\u001b]8;;\u0007\r\n    UniProt     \u001b]8;;https://www.uniprot.org/uniprotkb?query=gene:BRCA1+organism_id:9606\u0007\u001b[36mhttps://www.uniprot.org/uniprotkb?query=gene:BRCA1+organism_id:9606\u001b[0m\u001b]8;;\u0007\r\n    GeneCards   \u001b]8;;https://www.genecards.org/cgi-bin/carddisp.pl?gene=BRCA1\u0007\u001b[36mhttps://www.genecards.org/cgi-bin/carddisp.pl?gene=BRCA1\u001b[0m\u001b]8;;\u0007\r\n"]
